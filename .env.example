# Frontend
# Used by Vite API clients. Keep localhost for local development.
VITE_API_BASE_URL=http://127.0.0.1:8000

# Backend
# Comma-separated frontend origins allowed by FastAPI CORS.
# Example for a future deployment:
# DATAPULSE_CORS_ORIGINS=https://your-frontend.example.com
DATAPULSE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
